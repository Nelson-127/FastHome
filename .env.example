# Скопируйте в .env и заполните. Секреты не коммитьте.

# --- Telegram ---
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789

# --- API ↔ Bot (обязательно в проде) ---
INTERNAL_API_KEY=generate_a_long_random_string

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://flatbot:flatbot@localhost:5432/flatbot

# --- Public URLs ---
BACKEND_BASE_URL=http://127.0.0.1:8000
PUBLIC_API_BASE=http://127.0.0.1:8000

# --- Оплата: TBC (по умолчанию ВЫКЛ) ---
# Пока нет договора с TBC оставьте false — бот покажет реквизиты IBAN ниже.
TBC_ENABLED=false

# Ручной перевод (когда TBC_ENABLED=false)
IBAN_TBC=
IBAN_BOG=
RECIPIENT_NAME=

# --- TBC Pay (нужны только при TBC_ENABLED=true; см. docs/TBC_SETUP.md) ---
# TBC_APIKEY=
# TBC_CLIENT_ID=
# TBC_CLIENT_SECRET=
# TBC_RETURN_URL=https://your-domain.example/payment/done
# TBC_CALLBACK_URL=https://your-domain.example/payments/webhook
# TBC_WEBHOOK_SECRET=

# --- Admin web (Basic) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-strong-password

# Окружение: dev | prod
ENV=dev
